---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Image from '~/components/common/Image.astro';
import { TAXONOMY_LABELS } from '~/utils/case-studies';

interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  caseStudies: Array<CollectionEntry<'case-studies'>>;
  moreHref?: string;
  id?: string;
}

const {
  title = 'Take a look at our work',
  subtitle,
  tagline = 'Case studies',
  caseStudies = [],
  moreHref = '/case-studies',
  id,
} = Astro.props;

const tagsOf = (cs: CollectionEntry<'case-studies'>): string[] => [...cs.data.services, ...cs.data.industries];

const arrowClass =
  'inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-gray-300 bg-white transition hover:border-primary hover:text-primary disabled:cursor-not-allowed disabled:opacity-40 dark:border-gray-600 dark:bg-slate-900';
---

<WidgetWrapper id={id} containerClass="max-w-7xl mx-auto">
  <div data-cs-carousel>
    <div class="mb-8 flex items-center justify-between gap-4">
      <Headline
        tagline={tagline}
        title={title}
        subtitle={subtitle}
        classes={{ container: 'mb-0 md:mb-0 md:mx-0 max-w-2xl text-left' }}
      />
      <div class="flex shrink-0 gap-2" data-cs-controls>
        <button type="button" class={arrowClass} aria-label="Previous case studies" data-cs-prev>
          <Icon name="tabler:chevron-left" class="h-5 w-5" />
        </button>
        <button type="button" class={arrowClass} aria-label="Next case studies" data-cs-next>
          <Icon name="tabler:chevron-right" class="h-5 w-5" />
        </button>
      </div>
    </div>

    <div
      class="flex snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-2"
      role="region"
      aria-label="Case studies"
      tabindex="0"
      data-cs-track
    >
      {
        caseStudies.map((cs) => (
          <a
            href={`${moreHref}#${cs.id}`}
            class="group flex shrink-0 basis-[85%] snap-start flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:shadow-lg sm:basis-[60%] lg:basis-[42%] dark:border-gray-700 dark:bg-slate-900"
            data-cs-slide
          >
            {cs.data.image && (
              <Image
                class="w-full"
                width={600}
                height={338}
                widths={[400, 768]}
                sizes="(max-width: 640px) 85vw, (max-width: 1024px) 60vw, 480px"
                layout="responsive"
                format="webp"
                {...cs.data.image}
              />
            )}
            <div class="flex flex-1 flex-col p-6">
              <div class="flex flex-wrap gap-2">
                {tagsOf(cs).map((slug) => (
                  <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
                    {TAXONOMY_LABELS[slug as keyof typeof TAXONOMY_LABELS]}
                  </span>
                ))}
              </div>
              <h3 class="mt-3 text-xl font-bold">{cs.data.title}</h3>
              {cs.data.client && <p class="mt-1 text-sm text-muted">{cs.data.client}</p>}
              <p class="mt-2 text-muted" set:html={cs.data.excerpt} />
              <span class="mt-auto inline-flex items-center gap-1 pt-4 text-sm font-medium text-primary">
                Read more
                <Icon name="tabler:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</WidgetWrapper>

<script>
  function initCaseStudyCarousels() {
    document.querySelectorAll<HTMLElement>('[data-cs-carousel]').forEach((root) => {
      const track = root.querySelector<HTMLElement>('[data-cs-track]');
      const controls = root.querySelector<HTMLElement>('[data-cs-controls]');
      const prev = root.querySelector<HTMLButtonElement>('[data-cs-prev]');
      const next = root.querySelector<HTMLButtonElement>('[data-cs-next]');
      if (!track) return;

      const step = () => {
        const slide = track.querySelector<HTMLElement>('[data-cs-slide]');
        const gap = parseFloat(getComputedStyle(track).columnGap || '0') || 0;
        return slide ? slide.offsetWidth + gap : track.clientWidth;
      };

      const update = () => {
        const max = track.scrollWidth - track.clientWidth;
        const scrollable = max > 2;
        const atStart = track.scrollLeft <= 0;
        const atEnd = track.scrollLeft >= max - 1;
        controls?.classList.toggle('hidden', !scrollable);
        if (prev) prev.disabled = atStart;
        if (next) next.disabled = atEnd;
        // Fade the clipped card on whichever side still has content to scroll,
        // so it dissolves into the background instead of being cut off abruptly.
        track.style.setProperty('--cs-fade-l', scrollable && !atStart ? '14%' : '0px');
        track.style.setProperty('--cs-fade-r', scrollable && !atEnd ? '14%' : '0px');
      };

      prev?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
      next?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
      track.addEventListener('scroll', update, { passive: true });
      // ResizeObserver is tied to the element, so it is garbage-collected with it
      // on view-transition swaps — no leaked window listeners across navigations.
      new ResizeObserver(update).observe(track);
    });
  }

  // Runs on first load and after every view transition (ClientRouter).
  document.addEventListener('astro:page-load', initCaseStudyCarousels);
</script>

<style>
  /* Progressive fade on the scroll edges so a half-visible card blends into the
     background instead of ending on a hard cut. --cs-fade-l/r are toggled by the
     script (0 when that edge has nothing more to scroll). */
  [data-cs-track] {
    scrollbar-width: none;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 var(--cs-fade-l, 0px),
      #000 calc(100% - var(--cs-fade-r, 0px)),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 var(--cs-fade-l, 0px),
      #000 calc(100% - var(--cs-fade-r, 0px)),
      transparent 100%
    );
  }
  [data-cs-track]::-webkit-scrollbar {
    display: none;
  }
</style>
