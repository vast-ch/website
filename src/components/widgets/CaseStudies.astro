---
import type { CollectionEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Image from '~/components/common/Image.astro';
import { CASE_STUDY_SERVICES, CASE_STUDY_INDUSTRIES, TAXONOMY_LABELS } from '~/utils/case-studies';

interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  caseStudies: Array<CollectionEntry<'case-studies'>>;
  id?: string;
}

const { title, subtitle, tagline, caseStudies = [], id } = Astro.props;

const tagsOf = (cs: CollectionEntry<'case-studies'>): string[] => [...cs.data.services, ...cs.data.industries];

// Only offer filters that match at least one case study — services first, then industries.
const filters = [...CASE_STUDY_SERVICES, ...CASE_STUDY_INDUSTRIES]
  .filter((slug) => caseStudies.some((cs) => tagsOf(cs).includes(slug)))
  .map((slug) => ({ slug, label: TAXONOMY_LABELS[slug] }));

const pillClass =
  'cursor-pointer rounded-full border border-gray-300 dark:border-gray-600 px-4 py-2 text-sm transition hover:border-primary aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-white focus-visible:ring-2 focus-visible:ring-primary';
---

<WidgetWrapper id={id} containerClass="max-w-7xl mx-auto">
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  {
    filters.length > 0 && (
      <div
        class="mb-8 flex flex-wrap justify-center gap-2"
        role="group"
        aria-label="Filter case studies"
        data-cs-filters
      >
        <button type="button" data-filter="all" aria-pressed="true" class={pillClass}>
          All
        </button>
        {filters.map(({ slug, label }) => (
          <button type="button" data-filter={slug} aria-pressed="false" class={pillClass}>
            {label}
          </button>
        ))}
      </div>
    )
  }

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-3" data-cs-grid>
    {
      caseStudies.map((cs) => (
        <details
          id={cs.id}
          class="group relative flex flex-col scroll-mt-24 rounded-lg border border-[#ffffff29] bg-white p-6 shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur dark:bg-slate-900 dark:shadow-[0_4px_30px_rgba(0,0,0,0.1)]"
          data-cs-card
          data-tags={tagsOf(cs).join(' ')}
        >
          <summary class="flex flex-1 cursor-pointer list-none flex-col [&::-webkit-details-marker]:hidden">
            {cs.data.image && (
              <Image
                class="mb-4 w-full rounded-md"
                width={600}
                height={338}
                widths={[400, 768]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 400px"
                layout="responsive"
                format="webp"
                {...cs.data.image}
              />
            )}
            <div class="flex flex-wrap gap-2">
              {tagsOf(cs).map((slug) => (
                <span class="inline-block rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
                  {TAXONOMY_LABELS[slug as keyof typeof TAXONOMY_LABELS]}
                </span>
              ))}
            </div>
            <h3 class="mt-3 text-xl font-bold">{cs.data.title}</h3>
            {cs.data.client && <p class="mt-1 text-sm text-muted">{cs.data.client}</p>}
            <p class="mt-2 text-muted" set:html={cs.data.excerpt} />
            <span class="mt-auto inline-flex items-center gap-1 pt-4 text-sm font-medium text-primary">
              Details
              <Icon name="tabler:chevron-down" class="h-4 w-4 transition-transform group-open:rotate-180" />
            </span>
          </summary>

          <div class="mt-6 space-y-6 border-t border-gray-200 pt-6 dark:border-slate-700">
            {cs.data.items.map(({ title: itemTitle, description, icon }) => (
              <div class="flex flex-row max-w-none">
                <div class="flex justify-center">
                  <Icon
                    name={icon || 'tabler:check'}
                    class="flex h-7 w-7 items-center justify-center rounded-full bg-primary text-white dark:text-black p-1 mr-2 rtl:mr-0 rtl:ml-2"
                  />
                </div>
                <div class="mt-0.5">
                  {itemTitle && (
                    <h4 class="text-lg font-medium leading-6 dark:text-white ml-2 rtl:ml-0 rtl:mr-2">{itemTitle}</h4>
                  )}
                  {description && (
                    <p class="mt-3 text-muted dark:text-slate-400 ml-2 rtl:ml-0 rtl:mr-2" set:html={description} />
                  )}
                </div>
              </div>
            ))}
          </div>
        </details>
      ))
    }
  </div>
</WidgetWrapper>

<script>
  function initCaseStudyFilters() {
    const root = document.querySelector<HTMLElement>('[data-cs-filters]');
    if (!root) return;
    const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('button[data-filter]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-cs-card]'));

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter ?? 'all';
        pills.forEach((p) => p.setAttribute('aria-pressed', String(p === pill)));
        cards.forEach((card) => {
          const tags = (card.dataset.tags ?? '').split(' ');
          card.classList.toggle('hidden', filter !== 'all' && !tags.includes(filter));
        });
      });
    });
  }

  // Deep links (e.g. /case-studies#flightbook) land on the card expanded.
  function openCaseStudyFromHash() {
    const id = decodeURIComponent(window.location.hash.slice(1));
    if (!id) return;
    const card = document.getElementById(id);
    if (card instanceof HTMLDetailsElement && card.hasAttribute('data-cs-card')) card.open = true;
  }

  // Runs on first load and after every view transition (ClientRouter).
  document.addEventListener('astro:page-load', () => {
    initCaseStudyFilters();
    openCaseStudyFromHash();
  });
  window.addEventListener('hashchange', openCaseStudyFromHash);
</script>
