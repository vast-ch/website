---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(0 0 0);
    --aw-color-secondary: rgb(55 65 81);
    --aw-color-accent: rgb(0 0 0);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);
    --aw-color-bg-section: rgb(246 247 249);

    --aw-color-bg-page-dark: rgb(17 17 17);

    ::selection {
      background-color: rgb(229 231 235);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(243 244 246);
    --aw-color-secondary: rgb(209 213 219);
    --aw-color-accent: rgb(243 244 246);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 231 235);
    --aw-color-text-muted: rgb(229 231 235 / 66%);
    --aw-color-bg-page: rgb(17 17 17);
    --aw-color-bg-section: rgb(24 24 24);

    ::selection {
      background-color: rgb(75 85 99);
      color: snow;
    }
  }
</style>
