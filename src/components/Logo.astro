---
import { SITE } from 'astrowind:config';
import logoLight from '~/assets/images/logo.svg';
import logoDark from '~/assets/images/logo-white.svg';
---

<img src={logoLight.src} alt={SITE?.name} class="self-center ml-2 rtl:ml-0 rtl:mr-2 h-10 w-auto dark:hidden" />
<img src={logoDark.src} alt={SITE?.name} class="self-center ml-2 rtl:ml-0 rtl:mr-2 h-10 w-auto hidden dark:block" />
