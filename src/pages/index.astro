---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'vast.ch — Swiss software engineering studio',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Our services',
        href: '/services',
        icon: 'tabler:arrow-right',
      },
      { text: 'Get in touch', href: '/contact' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'vast.ch — Swiss engineering studio' }}
  >
    <Fragment slot="title">
      Software, data and technical guidance <span class="text-accent dark:text-white">from the Swiss Alps</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">vast.ch</span> is a three-person engineering studio based in Interlaken, Brig and Fribourg.
      We build web and mobile applications, develop forecasting models, and advise teams on the technical choices that matter.
    </Fragment>
  </Hero>

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="What we do"
    title="Three things we do well"
    subtitle="A focused practice rather than a long menu — so each project gets the attention it deserves."
    items={[
      {
        title: 'Web and application development',
        description:
          'Modern web and mobile apps, from the first sketch to a production system you can maintain. Strong on TypeScript, Astro, Ember, mobile and the boring-but-critical parts in between.',
        icon: 'tabler:code',
      },
      {
        title: 'Data science and forecasting',
        description:
          'Forecasting models, time-series analysis and machine-learning pipelines grounded in academic research and real production constraints.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'Technological advice',
        description:
          'Independent technical guidance for founders, product teams and managers — architecture reviews, stack choices, hiring help and second opinions.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">Have a project in mind?</Fragment>

    <Fragment slot="subtitle">
      Tell us what you're working on — in German, French or English. We'll get back to you within a few business days.
    </Fragment>
  </CallToAction>
</Layout>
