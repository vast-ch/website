---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import QuickStart from '~/components/widgets/QuickStart.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
if (!page) throw new Error('Missing page entry: contact');
const { metadata, hero, directContact, quickStart } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <div class="bg-section">
    <Hero tagline={hero.tagline} subtitle={hero.subtitle}>
      <Fragment slot="title">
        {hero.title}
        <span class="text-accent dark:text-white">{hero.titleAccent}</span>
      </Fragment>
    </Hero>
  </div>

  <QuickStart
    id={quickStart.id}
    title={directContact.title}
    subtitle={directContact.subtitle}
    contacts={directContact.items}
    formTitle={quickStart.title}
    categories={quickStart.categories}
    button={quickStart.button}
    consent={quickStart.consent}
  />
</Layout>
