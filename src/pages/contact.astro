---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'contact');
if (!page) throw new Error('Missing page entry: contact');
const { metadata, heroText, offices, languages, contactForm, directContact } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <HeroText
    tagline={heroText.tagline}
    title={heroText.title}
    subtitle={heroText.subtitle}
  />

  <Features2
    title={offices.title}
    subtitle={offices.subtitle}
    columns={offices.columns}
    items={offices.items}
  />

  <Features2
    title={languages.title}
    subtitle={languages.subtitle}
    columns={languages.columns}
    items={languages.items}
  />

  <ContactUs
    id={contactForm.id}
    title={contactForm.title}
    subtitle={contactForm.subtitle}
    inputs={contactForm.inputs}
    textarea={contactForm.textarea}
    disclaimer={contactForm.disclaimer}
    description={contactForm.description}
  />

  <Features2
    title={directContact.title}
    columns={directContact.columns}
    items={directContact.items}
  />
</Layout>
