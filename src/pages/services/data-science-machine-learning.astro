---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import TechLogos from '~/components/widgets/TechLogos.astro';
import QuickStart from '~/components/widgets/QuickStart.astro';
import CaseStudyHighlight from '~/components/widgets/CaseStudyHighlight.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services/data-science');
if (!page) throw new Error('Missing page entry: services/data-science');
const { metadata, hero, forecasting, tabular, toolbox, tech, proof, caseStudy, nextSteps, quickStart } =
  page.data as Required<typeof page.data>;

const caseStudyEntry = await getEntry('case-studies', caseStudy);
if (!caseStudyEntry) throw new Error(`Missing case study entry: ${caseStudy}`);
---

<Layout metadata={metadata}>
  <div class="bg-section">
    <Hero tagline={hero.tagline} title={hero.title} subtitle={hero.subtitle} />

    <Features2
      title={proof.title}
      tagline={proof.tagline}
      subtitle={proof.subtitle}
      columns={proof.columns}
      items={proof.items}
    />
  </div>

  <Content isReversed={forecasting.isReversed} items={forecasting.items} image={forecasting.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{forecasting.contentHeading}</h3>
      {forecasting.contentBody}
    </Fragment>
  </Content>

  <Content isReversed={tabular.isReversed} items={tabular.items} image={tabular.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{tabular.contentHeading}</h3>
      {tabular.contentBody}
    </Fragment>
  </Content>

  <Content isReversed={toolbox.isReversed} items={toolbox.items} image={toolbox.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{toolbox.contentHeading}</h3>
      {toolbox.contentBody}
    </Fragment>
  </Content>

  <TechLogos title={tech.title} tagline={tech.tagline} subtitle={tech.subtitle} items={tech.items} />

  <div class="bg-section">
    <CaseStudyHighlight caseStudy={caseStudyEntry.data} />
  </div>

  <QuickStart
    tagline={nextSteps.tagline}
    title={nextSteps.title}
    subtitle={nextSteps.subtitle}
    steps={nextSteps.items}
    formTitle={quickStart.title}
    categories={quickStart.categories}
    button={quickStart.button}
    consent={quickStart.consent}
  />
</Layout>
