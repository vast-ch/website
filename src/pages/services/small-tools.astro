---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import TechLogos from '~/components/widgets/TechLogos.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services/small-tools');
if (!page) throw new Error('Missing page entry: services/small-tools');
const { metadata, hero, examples, categories, approach, tech, whenItFits, cta } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <div class="bg-section">
    <Hero
      tagline={hero.tagline}
      title={hero.title}
      subtitle={hero.subtitle}
    />

    <Content
      isReversed={examples.isReversed}
      items={examples.items}
      image={examples.image}
    >
      <Fragment slot="content">
        <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{examples.contentHeading}</h3>
        {examples.contentBody}
      </Fragment>
    </Content>
  </div>

  <Features2
    title={categories.title}
    tagline={categories.tagline}
    subtitle={categories.subtitle}
    columns={categories.columns}
    items={categories.items}
  />

  <Content
    isAfterContent={approach.isAfterContent}
    items={approach.items}
    image={approach.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{approach.contentHeading}</h3>
      {approach.contentBody}
    </Fragment>
  </Content>

  <TechLogos
    title={tech.title}
    tagline={tech.tagline}
    subtitle={tech.subtitle}
    items={tech.items}
  />

  <div class="bg-section">
    <Features2
      title={whenItFits.title}
      tagline={whenItFits.tagline}
      subtitle={whenItFits.subtitle}
      columns={whenItFits.columns}
      items={whenItFits.items}
    />
  </div>

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>
