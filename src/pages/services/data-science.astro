---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services/data-science');
if (!page) throw new Error('Missing page entry: services/data-science');
const { metadata, hero, capabilities, proof, howWeWork, cta } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <Hero
    tagline={hero.tagline}
    title={hero.title}
    subtitle={hero.subtitle}
  />

  <Content
    isReversed={capabilities.isReversed}
    items={capabilities.items}
    image={capabilities.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{capabilities.contentHeading}</h3>
      {capabilities.contentBody}
    </Fragment>
  </Content>

  <Features2
    title={proof.title}
    tagline={proof.tagline}
    subtitle={proof.subtitle}
    columns={proof.columns}
    items={proof.items}
  />

  <Content
    isAfterContent={howWeWork.isAfterContent}
    items={howWeWork.items}
    image={howWeWork.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{howWeWork.contentHeading}</h3>
      {howWeWork.contentBody}
    </Fragment>
  </Content>

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>
