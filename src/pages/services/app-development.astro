---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import TechLogos from '~/components/widgets/TechLogos.astro';
import QuickStart from '~/components/widgets/QuickStart.astro';
import CaseStudyHighlight from '~/components/widgets/CaseStudyHighlight.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services/web-development');
if (!page) throw new Error('Missing page entry: services/web-development');
const { metadata, hero, web, mobile, backend, tech, proof, caseStudy, nextSteps, quickStart } = page.data as Required<
  typeof page.data
>;

const caseStudyEntry = await getEntry('case-studies', caseStudy);
if (!caseStudyEntry) throw new Error(`Missing case study entry: ${caseStudy}`);
---

<Layout metadata={metadata}>
  <div class="bg-section">
    <Hero tagline={hero.tagline} title={hero.title} subtitle={hero.subtitle} />

    <Features2 title={proof.title} tagline={proof.tagline} columns={proof.columns} items={proof.items} />
  </div>

  <Content isReversed={web.isReversed} items={web.items} image={web.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{web.contentHeading}</h3>
      {web.contentBody}
    </Fragment>
  </Content>

  <Content isReversed={mobile.isReversed} isAfterContent={mobile.isAfterContent} items={mobile.items} image={mobile.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{mobile.contentHeading}</h3>
      {mobile.contentBody}
    </Fragment>
  </Content>

  <Content isReversed={backend.isReversed} items={backend.items} image={backend.image}>
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{backend.contentHeading}</h3>
      {backend.contentBody}
    </Fragment>
  </Content>

  <TechLogos title={tech.title} tagline={tech.tagline} subtitle={tech.subtitle} items={tech.items} />

  <div class="bg-section">
    <CaseStudyHighlight caseStudy={caseStudyEntry.data} />
  </div>

  <QuickStart
    tagline={nextSteps.tagline}
    title={nextSteps.title}
    subtitle={nextSteps.subtitle}
    steps={nextSteps.items}
    formTitle={quickStart.title}
    categories={quickStart.categories}
    button={quickStart.button}
    consent={quickStart.consent}
  />
</Layout>
