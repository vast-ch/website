---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Advisory and digitalization solutions',
  description:
    'Independent architecture reviews, stack and vendor choices, technical hiring help, and digitalization solutions — process digitization, workflow automation and custom internal tools. From senior engineers with no skin in the implementation.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Advisory & digitalization"
    title="Independent advice and practical digitalization"
    subtitle="Two sides of the same work: clear-eyed advice on the decisions that shape your software, and hands-on digitalization of the processes still living in spreadsheets and paper. For founders, operators and teams that want a senior partner without an agency in the middle."
  />

  <!-- Content Widget — What we advise on -->

  <Content
    isReversed
    items={[
      {
        title: 'Architecture reviews',
        description:
          'A senior read of the system you have, or the one you are about to build — strengths, risks, single points of failure, and what we would change if it were ours.',
        icon: 'tabler:building-arch',
      },
      {
        title: 'Stack and vendor choices',
        description:
          'Which framework, which database, which cloud, which tool. The decision is easier to live with when an independent voice helps make it — especially one familiar with the trade-offs each option will create three years from now.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Hiring and team setup',
        description:
          'Job descriptions, technical interviews, screening engineers, structuring a first dev team. Practical help for founders and operators building technical capacity for the first time.',
        icon: 'tabler:users',
      },
      {
        title: 'Second opinions',
        description:
          'An offer is on the table, a vendor is pushing a solution, an internal proposal needs scrutiny. We provide the independent read — written, defensible, and short enough to read in one sitting.',
        icon: 'tabler:eye-check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2194&q=80',
      alt: 'Technical strategy session',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">What we advise on</h3>
      Concrete questions, concrete answers. We do not sell strategy decks.
    </Fragment>
  </Content>

  <!-- Features2 Widget — Digitalization solutions -->

  <Features2
    title="Digitalization solutions"
    tagline="Going digital"
    subtitle="The practical side of the work — turning processes that live in paper, spreadsheets and email into software that actually fits the team."
    columns={2}
    items={[
      {
        title: 'Process digitization',
        description:
          'Mapping the workflow as it is, then designing the smallest software change that removes the painful parts. Forms, approvals, records and signatures — moved out of paper and spreadsheets without inventing a new bureaucracy.',
        icon: 'tabler:transform',
      },
      {
        title: 'Workflow automation',
        description:
          'Repetitive steps connected end-to-end so people can stop being the integration layer. Scheduled jobs, event-driven pipelines, sensible alerts when something needs a human.',
        icon: 'tabler:robot',
      },
      {
        title: 'Internal tools and dashboards',
        description:
          'Custom admin panels, operational dashboards and back-office tools built for one team and one job — not a generic SaaS that does 60% of what you need.',
        icon: 'tabler:dashboard',
      },
      {
        title: 'SaaS selection and integration',
        description:
          'Sometimes the right answer is not to build. We help you pick the right off-the-shelf tools, integrate them with what you already use, and avoid lock-in you will regret in two years.',
        icon: 'tabler:plug-connected',
      },
    ]}
  />

  <!-- Features2 Widget — When it fits -->

  <Features2
    title="When this is the right call"
    tagline="When it fits"
    subtitle="Most teams contact us at one of these inflection points — for an opinion, a digitalization project, or both."
    columns={2}
    items={[
      {
        title: 'Before signing with a vendor',
        description:
          'A six-figure proposal deserves a second opinion that costs a fraction of it. We read the offer, the architecture and the contract, and tell you what we see.',
        icon: 'tabler:file-text',
      },
      {
        title: 'Before a big refactor',
        description:
          'Tearing up a working system is expensive. We help you decide whether the rewrite is justified — and, if so, how to do it without rebuilding the wrong thing.',
        icon: 'tabler:refresh',
      },
      {
        title: 'Before hiring your first engineers',
        description:
          'Job descriptions, technical interviews, screening calls. We have shipped at every level of the stack and have hired against most of it.',
        icon: 'tabler:user-plus',
      },
      {
        title: 'Before a board or funding meeting',
        description:
          'Independent technical due diligence — written in plain language, defensible under scrutiny, and aware of the audience reading it.',
        icon: 'tabler:presentation',
      },
    ]}
  />

  <!-- Content Widget — How it works *** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Short engagements',
        description:
          'Most advisory work runs from a few hours to a few days. Long enough to understand the problem; short enough to keep us honest and your invoice predictable.',
        icon: 'tabler:clock',
      },
      {
        title: 'Written conclusions',
        description:
          'You get a short, plain-language document at the end — something you can share with your board, your CTO or your future self when the same question comes back next year.',
        icon: 'tabler:file-text',
      },
      {
        title: 'No lock-in',
        description:
          'We are happy to help implement what we recommended — and just as happy if you take it to your existing team or another partner. Our recommendation does not depend on who builds it.',
        icon: 'tabler:lock-open',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Notes from an advisory session',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">How it works</h3>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Ask us anything',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
    title="Have a decision to make — or a process to digitize?"
    subtitle="Send the question or the workflow through. If it is something we can help with, we will say so — and if not, we will point you somewhere useful."
  />
</Layout>
