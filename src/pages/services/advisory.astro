---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services/advisory');
if (!page) throw new Error('Missing page entry: services/advisory');
const { metadata, hero, whatWeAdviseOn, digitalization, whenItFits, howItWorks, cta } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <Hero
    tagline={hero.tagline}
    title={hero.title}
    subtitle={hero.subtitle}
  />

  <Content
    isReversed={whatWeAdviseOn.isReversed}
    items={whatWeAdviseOn.items}
    image={whatWeAdviseOn.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{whatWeAdviseOn.contentHeading}</h3>
      {whatWeAdviseOn.contentBody}
    </Fragment>
  </Content>

  <Features2
    title={digitalization.title}
    tagline={digitalization.tagline}
    subtitle={digitalization.subtitle}
    columns={digitalization.columns}
    items={digitalization.items}
  />

  <Features2
    title={whenItFits.title}
    tagline={whenItFits.tagline}
    subtitle={whenItFits.subtitle}
    columns={whenItFits.columns}
    items={whenItFits.items}
  />

  <Content
    isAfterContent={howItWorks.isAfterContent}
    items={howItWorks.items}
    image={howItWorks.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{howItWorks.contentHeading}</h3>
      {howItWorks.contentBody}
    </Fragment>
  </Content>

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>
