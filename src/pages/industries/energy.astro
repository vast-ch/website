---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'industries/energy');
if (!page) throw new Error('Missing page entry: industries/energy');
const { metadata, hero, whatsHard, proof, approach, cta } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <Hero
    tagline={hero.tagline}
    title={hero.title}
    subtitle={hero.subtitle}
  />

  <Content
    isReversed={whatsHard.isReversed}
    items={whatsHard.items}
    image={whatsHard.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{whatsHard.contentHeading}</h3>
      {whatsHard.contentBody}
    </Fragment>
  </Content>

  <Features2
    title={proof.title}
    tagline={proof.tagline}
    subtitle={proof.subtitle}
    columns={proof.columns}
    items={proof.items}
  />

  <Content
    isAfterContent={approach.isAfterContent}
    items={approach.items}
    image={approach.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{approach.contentHeading}</h3>
      {approach.contentBody}
    </Fragment>
  </Content>

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>
