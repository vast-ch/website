---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About vast.ch — Swiss engineering studio',
  description:
    'vast.ch is a small Swiss engineering studio. Co-founders Frédéric Montet (PhD, ML), Michal Bryxí (Ember, frontend) and Yannick Lagger (mobile, FHIR). Based in Interlaken, Brig and Fribourg.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About us"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'The Swiss Alps',
    }}
  >
    <Fragment slot="title">
      A small Swiss team building <span class="text-accent dark:text-white">software that matters</span>
    </Fragment>

    <Fragment slot="subtitle">
      vast.ch is a small engineering studio based in Switzerland. We design and build web and mobile applications, train
      forecasting models, and advise founders and product teams on the technical decisions that shape their work.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="vast.ch at a glance"
    stats={[
      { title: 'Engineers', amount: '3' },
      { title: 'Offices', amount: '3' },
      { title: 'Languages', amount: '3' },
      { title: 'Founded', amount: '2020' },
    ]}
  />

  <!-- Features2 Widget — Team ******** -->

  <Features2
    title="The team"
    subtitle="The engineers who built vast.ch around the projects we actually want to work on."
    columns={3}
    items={[
      {
        title: 'Frédéric Montet',
        description:
          'Co-founder. PhD in Computer Science (HES-SO). Focus on data science, machine learning and forecasting. Based in Interlaken.',
        icon: 'tabler:chart-line',
        callToAction: {
          variant: 'link',
          text: 'LinkedIn',
          href: 'https://ch.linkedin.com/in/fredmontet',
          target: '_blank',
          icon: 'tabler:brand-linkedin',
        },
      },
      {
        title: 'Michal Bryxí',
        description:
          'Co-founder. Software engineer with a frontend focus. Previously at Puppet. Long-time Ember and JavaScript contributor. Based in Interlaken.',
        icon: 'tabler:code',
        callToAction: {
          variant: 'link',
          text: 'LinkedIn',
          href: 'https://www.linkedin.com/in/michalbryxi/',
          target: '_blank',
          icon: 'tabler:brand-linkedin',
        },
      },
      {
        title: 'Yannick Lagger',
        description:
          'Co-founder. Software engineer with a mobile and web background (HES-SO). Publishes apps under his own name, including Flightbook. Based in Brig.',
        icon: 'tabler:device-mobile',
        callToAction: {
          variant: 'link',
          text: 'LinkedIn',
          href: 'https://www.linkedin.com/in/yannick-lagger-302070193/?locale=en_US',
          target: '_blank',
          icon: 'tabler:brand-linkedin',
        },
      },
    ]}
  />

  <!-- Features2 Widget — Proof points ** -->

  <Features2
    title="What we have actually shipped"
    tagline="The receipts"
    subtitle="A decade of combined output — peer-reviewed research, open-source tools and apps in production stores."
    columns={2}
    items={[
      {
        title: 'Peer-reviewed publications',
        description:
          'PhD in Computer Science (HES-SO, 2025) and multiple journal and conference papers on building-energy forecasting, Big Building Data and foundation models for time series.',
        icon: 'tabler:school',
      },
      {
        title: 'Open-source tools in active use',
        description:
          'onTime (Python time-series benchmarking), vscode-fhir-tools (clinical data tooling used internationally), Ember addons and infrastructure-as-code modules.',
        icon: 'tabler:brand-github',
      },
      {
        title: 'Apps in production',
        description:
          'Own products on the App Store and Google Play — including Flightbook, used by paragliding pilots and instructors and shipped in four languages.',
        icon: 'tabler:apps',
      },
      {
        title: 'Industrial and research projects',
        description:
          'Engagements with universities, research institutes, healthcare interoperability teams and Swiss SMEs — across energy, smart buildings, healthcare and mobility.',
        icon: 'tabler:briefcase',
      },
    ]}
  />

  <!-- Steps2 Widget — Values *********** -->

  <Steps2
    title="How we work"
    subtitle="The principles that shape every project we take on."
    items={[
      {
        title: 'Small team, direct contact',
        description:
          'You talk to the engineers doing the work — not account managers. A small team means decisions move fast and nothing gets lost in translation.',
      },
      {
        title: 'Pragmatic over trendy',
        description:
          'We pick the stack that fits the problem and the people who will maintain it after we leave. Long-term simplicity beats short-term cleverness.',
      },
      {
        title: 'Built for Switzerland',
        description:
          'Offices in Interlaken, Brig and Fribourg, working in Swiss German, French and English, and a calendar that respects how things actually get done here. We meet you where you are.',
      },
    ]}
  />

  <!-- Features2 Widget — Offices ****** -->

  <Features2
    title="Where we are"
    tagline="Offices"
    subtitle="Locations across Switzerland — we can meet you in person or work fully remotely."
    columns={3}
    items={[
      {
        title: 'Interlaken',
        description: 'Berner Oberland — between the lakes, where vast.ch started.',
        icon: 'tabler:mountain',
      },
      {
        title: 'Brig',
        description: 'Valais — at the foot of the Simplon, our connection to the south.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Fribourg',
        description: 'Registered office at Innovation Lab Fribourg, on the Swiss language border.',
        icon: 'tabler:building',
      },
    ]}
  />

  <!-- Features2 Widget — Languages **** -->

  <Features2
    title="Languages we work in"
    tagline="Languages"
    columns={3}
    items={[
      {
        title: 'Swiss German',
        description: 'Schweizerdeutsch und Hochdeutsch — for meetings, documents and day-to-day work.',
        icon: 'tabler:message-language',
      },
      {
        title: 'French',
        description: 'Français — pour les projets en Suisse romande et au-delà.',
        icon: 'tabler:message-language',
      },
      {
        title: 'English',
        description: 'For international teams, technical writing and everything in between.',
        icon: 'tabler:message-language',
      },
    ]}
  />
</Layout>
