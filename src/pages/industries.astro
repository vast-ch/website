---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'industries');
if (!page) throw new Error('Missing page entry: industries');
const { metadata, hero, industries, whyTheseIndustries, cta } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <Hero
    tagline={hero.tagline}
    title={hero.title}
    subtitle={hero.subtitle}
  />

  <Features3
    title={industries.title}
    subtitle={industries.subtitle}
    columns={industries.columns}
    items={industries.items}
  />

  <Content
    isReversed={whyTheseIndustries.isReversed}
    items={whyTheseIndustries.items}
    image={whyTheseIndustries.image}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">{whyTheseIndustries.contentHeading}</h3>
      {whyTheseIndustries.contentBody}
    </Fragment>
  </Content>

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>
