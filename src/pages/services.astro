---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'services');
if (!page) throw new Error('Missing page entry: services');
const { metadata, hero, services, industries, techStack, cta } = page.data as Required<typeof page.data>;
---

<Layout metadata={metadata}>
  <Hero
    tagline={hero.tagline}
    title={hero.title}
    subtitle={hero.subtitle}
  />

  <Features3
    title={services.title}
    subtitle={services.subtitle}
    columns={services.columns}
    items={services.items}
  />

  <Features3
    title={industries.title}
    tagline={industries.tagline}
    subtitle={industries.subtitle}
    columns={industries.columns}
    items={industries.items}
  />

  <Features2
    title={techStack.title}
    tagline={techStack.tagline}
    subtitle={techStack.subtitle}
    columns={techStack.columns}
    items={techStack.items}
  />

  <CallToAction
    actions={cta.actions}
    title={cta.title}
    subtitle={cta.subtitle}
  />
</Layout>
