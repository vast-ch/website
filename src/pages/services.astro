---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Services"
    title="What we do at vast.ch"
    subtitle="A small, focused practice — three engineers, three offices, three working languages. We work on a handful of projects at a time so each one gets real attention."
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Three services"
    subtitle="Pick the one closest to what you need — or send us your question and we'll tell you where it fits."
    columns={3}
    items={[
      {
        title: 'Web and application development',
        description:
          'Modern web and mobile applications, from prototype to production system — built to be maintained for years.',
        icon: 'tabler:code',
        callToAction: {
          text: 'Learn more',
          href: '/services/web-development',
          icon: 'tabler:chevron-right',
        },
      },
      {
        title: 'Data science and forecasting',
        description:
          'Forecasting models, time-series analysis and machine-learning pipelines designed for production, not just notebooks.',
        icon: 'tabler:chart-line',
        callToAction: {
          text: 'Learn more',
          href: '/services/data-science',
          icon: 'tabler:chevron-right',
        },
      },
      {
        title: 'Technological advice',
        description:
          'Independent technical guidance — architecture reviews, stack choices, hiring help and second opinions.',
        icon: 'tabler:bulb',
        callToAction: {
          text: 'Learn more',
          href: '/services/advisory',
          icon: 'tabler:chevron-right',
        },
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Contact us',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
    title="Not sure which one fits?"
    subtitle="Describe the project in a sentence or two — we'll point you to the right place, or tell you honestly if it isn't a fit."
  />
</Layout>
